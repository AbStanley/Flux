{
  "name": "flux-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "client:dev": "npm run dev --workspace=@flux/client",
    "extension:dev": "npm run dev:extension --workspace=@flux/client",
    "server:dev": "npm run start:dev --workspace=@flux/server",
    "prisma-prepare": "npx prisma generate --workspace=@flux/server",
    "prisma-studio": "npx prisma studio --schema=apps/server/prisma/schema.prisma",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "prepare": "husky",
    "build": "npm run build --workspaces",
    "start:local:dev": "start \"Client\" npm run client:dev & start \"Server\" npm run server:dev",
    "db:dev": "docker compose -f docker-compose.dev.yml -p flux-dev up -d postgres",
    "docker:dev": "docker compose -f docker-compose.dev.yml -p flux-dev up --build",
    "docker:prod": "docker compose -f docker-compose.yml -p flux-prod up --build",
    "docker:prod:no-cache": "docker compose -f docker-compose.yml -p flux-prod build --no-cache && docker compose -f docker-compose.yml -p flux-prod up -d"
  },
  "overrides": {
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18",
    "@xmldom/xmldom": "0.9.10",
    "lodash": "4.17.21",
    "serialize-javascript": "7.0.5",
    "fast-uri": "3.1.2",
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "concurrently": "8.2.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0"
  },
  "lint-staged": {
    "apps/client/**/*.{ts,tsx}": [
      "npm exec --workspace=@flux/client -- eslint --fix"
    ]
  }
}
