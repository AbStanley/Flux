PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/flux_db
OLLAMA_HOST=http://localhost:11434

# --- SECURITY ---
# Secret key used for signing JWT tokens. Keep this secure in production!
JWT_SECRET=flux-dev-secret-change-me

# --- ACCESS CONTROL & QUOTAS ---
# Default daily limit for standard users who do not have custom overrides.
DEFAULT_DAILY_AI_LIMIT=100

# --- AI PROVIDER SELECTION ---
# Default is 'ollama'. Uncomment to switch to hosted Gemini or OpenRouter.
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_actual_gemini_api_key_here
# OPENROUTER_API_KEY=your_actual_openrouter_api_key_here
