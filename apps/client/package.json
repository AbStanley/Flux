{
  "name": "@flux/client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:extension": "vite build --watch",
    "build": "tsc -b && vite build",
    "build:local": "tsc -b && vite build --mode local",
    "build:dev": "tsc -b && vite build --mode development",
    "start": "pnpm run build && pnpm run dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:up": "docker compose -p flux-prod up -d --build",
    "docker:dev": "docker compose -f ../../docker-compose.dev.yml -p flux-dev up --build",
    "docker:down": "docker compose -p flux-prod down",
    "build:all": "pnpm run build && pnpm run docker:up",
    "prepare": "husky"
  },
  "dependencies": {
