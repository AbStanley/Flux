# --- DEVELOPMENT DEV SERVER SETTINGS ---
# Port to run the Vite local development server on.
VITE_PORT=5173

# Target URL of your local NestJS backend API (for proxying dev calls).
VITE_API_TARGET=http://127.0.0.1:3000

# --- PRODUCTION BUILD SETTINGS ---
# The public URL of your deployed backend NestJS API (for Chrome Extension build).
VITE_EXT_API_URL=https://api.yourdomain.com

# The public URL of your deployed backend NestJS API (for Web App build).
VITE_API_URL=https://api.yourdomain.com

# Build Mode Flag ('true' for standard React Web App, empty or 'false' for Chrome Extension).
VITE_IS_WEB_APP=false