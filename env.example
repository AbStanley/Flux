# Flux - Main Environment Variables & Secrets
JWT_SECRET=MY_SECRET_KEY
CADDY_PORT_DEV=8443
CADDY_PORT_PROD=443
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/flux_db

# --- AI PROVIDER SELECTION ---
# Default is 'ollama'. Set to 'gemini' or 'openrouter' to switch provider.
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_actual_gemini_api_key_here
# OPENROUTER_API_KEY=your_actual_openrouter_api_key_here

# --- ACCESS CONTROL & QUOTAS ---
# Default limit is 100 requests per day for standard users.
DEFAULT_DAILY_AI_LIMIT=100